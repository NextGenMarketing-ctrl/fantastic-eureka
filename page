const VERT=`
attribute float size;
attribute vec3 randomDir;
attribute float seed;

varying vec3 vColor;
varying float vMouseEffect;
varying float vDepth;
varying float vSpark;

uniform float time;
uniform vec2 uMouse;
uniform float uExplode;
uniform float uClick;

vec3 mod289(vec3 x){return x-floor(x*(1./289.))*289.;}
vec4 mod289(vec4 x){return x-floor(x*(1./289.))*289.;}
vec4 permute(vec4 x){return mod289(((x*34.)+1.)*x);}
vec4 taylorInvSqrt(vec4 r){return 1.79284291400159-0.85373472095314*r;}

float snoise(vec3 v){
  const vec2 C=vec2(1./6.,1./3.);
  const vec4 D=vec4(0.,.5,1.,2.);
  vec3 i=floor(v+dot(v,C.yyy));
  vec3 x0=v-i+dot(i,C.xxx);
  vec3 g=step(x0.yzx,x0.xyz);
  vec3 l=1.-g;
  vec3 i1=min(g.xyz,l.zxy);
  vec3 i2=max(g.xyz,l.zxy);
  vec3 x1=x0-i1+C.xxx;
  vec3 x2=x0-i2+C.yyy;
  vec3 x3=x0-D.yyy;
  i=mod289(i);
  vec4 p=permute(permute(permute(i.z+vec4(0.,i1.z,i2.z,1.))+i.y+vec4(0.,i1.y,i2.y,1.))+i.x+vec4(0.,i1.x,i2.x,1.));
  float n_=0.142857142857;
  vec3 ns=n_*D.wyz-D.xzx;
  vec4 j=p-49.*floor(p*ns.z*ns.z);
  vec4 x_=floor(j*ns.z);
  vec4 y_=floor(j-7.*x_);
  vec4 x=x_*ns.x+ns.yyyy;
  vec4 y=y_*ns.x+ns.yyyy;
  vec4 h=1.-abs(x)-abs(y);
  vec4 b0=vec4(x.xy,y.xy);
  vec4 b1=vec4(x.zw,y.zw);
  vec4 s0=floor(b0)*2.+1.;
  vec4 s1=floor(b1)*2.+1.;
  vec4 sh=-step(h,vec4(0.));
  vec4 a0=b0.xzyw+s0.xzyw*sh.xxyy;
  vec4 a1=b1.xzyw+s1.xzyw*sh.zzww;
  vec3 p0=vec3(a0.xy,h.x);
  vec3 p1=vec3(a0.zw,h.y);
  vec3 p2=vec3(a1.xy,h.z);
  vec3 p3=vec3(a1.zw,h.w);
  vec4 norm=taylorInvSqrt(vec4(dot(p0,p0),dot(p1,p1),dot(p2,p2),dot(p3,p3)));
  p0*=norm.x; p1*=norm.y; p2*=norm.z; p3*=norm.w;
  vec4 m=max(.6-vec4(dot(x0,x0),dot(x1,x1),dot(x2,x2),dot(x3,x3)),0.);
  m=m*m;
  return 42.*dot(m*m,vec4(dot(p0,x0),dot(p1,x1),dot(p2,x2),dot(p3,x3)));
}

void main(){
  vColor=color;

  vec3 p=position;
  float dist=length(p);
  vec3 n=normalize(p + randomDir * 0.001);

  // Slow "living cloud" motion instead of chaotic demo wobble.
  float flowA=snoise(p*1.15 + randomDir*0.8 + vec3(time*0.22, time*0.08, -time*0.16));
  float flowB=snoise(p*2.35 + vec3(-time*0.11, seed*2.0, time*0.18));
  float breath=sin(time*1.15 + seed*6.283 + dist*1.8) * 0.055;

  p += n * (flowA*0.16 + flowB*0.055 + breath);
  p += randomDir * flowB * 0.045;

  // Screen-space mouse interaction: particles near the cursor flare and get nudged.
  vec4 raw=projectionMatrix*modelViewMatrix*vec4(p,1.0);
  vec2 screenPos=raw.xy/raw.w;
  float mDist=distance(screenPos,uMouse);
  float mouse=1.0-smoothstep(0.0,0.34,mDist);
  mouse=mouse*mouse*(3.0-2.0*mouse);
  vMouseEffect=mouse;

  vec2 away=normalize(screenPos-uMouse+vec2(0.0001));
  p.xy += away * mouse * 0.52;
  p += n * mouse * 0.34;

  // Click ripple and explosion still exist, but feel like particle energy, not a gimmick.
  float wave=sin(dist*6.0-time*9.0);
  p += n * uClick * wave * 0.42;

  float explodeNoise=snoise(p*0.5+randomDir*2.0+time*0.8);
  p += randomDir * uExplode * (16.0 + explodeNoise*4.0);

  vec4 mvPos=modelViewMatrix*vec4(p,1.0);
  vDepth=clamp((-mvPos.z-12.0)/28.0,0.0,1.0);
  vSpark=mouse + max(0.0, flowB)*0.28 + uClick*0.6;

  float cameraScale=300.0/-mvPos.z;
  float pointSize=size * cameraScale * (1.0 + mouse*2.15 + uClick*0.75 + uExplode*0.9);
  gl_PointSize=clamp(pointSize,0.65,8.0);
  gl_Position=projectionMatrix*mvPos;
}`;

const FRAG=`
varying vec3 vColor;
varying float vMouseEffect;
varying float vDepth;
varying float vSpark;

uniform float time;
uniform float uExplode;
uniform float uClick;
uniform vec3 uPulseColor;
uniform float uPulseAmt;

float rand(vec2 co){return fract(sin(dot(co.xy,vec2(12.9898,78.233)))*43758.5453);}

void main(){
  vec2 uv=gl_PointCoord*2.0-1.0;
  float r=dot(uv,uv);
  if(r>1.0) discard;

  float core=smoothstep(1.0,0.0,r);
  float halo=exp(-r*4.0);
  float rim=pow(1.0-r,1.8);
  float twinkle=0.88 + rand(gl_PointCoord + vec2(time*0.03, time*0.017))*0.18;

  vec3 c=mix(vColor,uPulseColor,uPulseAmt*0.18);
  c=mix(c,vec3(0.90,0.97,1.0),vMouseEffect*0.72);
  c=mix(c,vec3(1.0),uClick*0.36+uExplode*0.78);

  float alpha=(halo*0.72 + core*0.42 + rim*0.22) * twinkle;
  alpha *= 0.72 + vSpark*0.42;
  alpha *= 0.88 + vDepth*0.16;

  gl_FragColor=vec4(c*(1.0+vSpark*0.65),alpha);
}`;

