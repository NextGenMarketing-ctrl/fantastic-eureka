  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }
  .user-bubble {
    background: rgba(0,40,100,0.06);
    border: 1px solid rgba(0,40,100,0.1);
    border-radius: 12px;
    padding: 10px 16px;
    margin-bottom: 10px;
    text-align: right;
