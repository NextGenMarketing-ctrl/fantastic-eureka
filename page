const SUGGESTIONS = ["View UX Projects","Case Studies","Palmer's design process","Resume","About Palmer","How to contact Palmer"];
const cortexInput = document.getElementById('cortex-input');
let sIdx=0,charIdx=0,deleting=false,pausing=false;
function typewriter(){
  if(document.activeElement===cortexInput){ setTimeout(typewriter,400); return; }
  const target=SUGGESTIONS[sIdx];
  if(pausing) return;
  if(!deleting){
    charIdx++; cortexInput.placeholder=target.slice(0,charIdx);
    if(charIdx===target.length){ pausing=true; setTimeout(()=>{ pausing=false; deleting=true; typewriter(); },2200); }
    else setTimeout(typewriter,68);
  } else {
    charIdx--; cortexInput.placeholder=target.slice(0,charIdx);
    if(charIdx===0){ deleting=false; sIdx=(sIdx+1)%SUGGESTIONS.length; setTimeout(typewriter,420); }
    else setTimeout(typewriter,32);
  }
}
setTimeout(typewriter,3800);

/* ── Apple nav item clicks ── */
