function makeMaterial(){
  return new THREE.ShaderMaterial({
    uniforms:{
      time:{value:0},
      uMouse:{value:mouse},
      uExplode:{value:0},
      uClick:{value:0},
      uPulseColor:{value:new THREE.Vector3(0,0,0)},
