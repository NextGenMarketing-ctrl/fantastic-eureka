    font-family: var(--font-ui); font-size: 16px; font-weight: 300;
    line-height: 1.75; color: rgba(20,30,60,0.85);
  }
  .bubble-text b { color: rgba(20,30,60,0.95); font-weight: 600; }
  .bubble-text i { color: rgba(20,30,60,0.6); font-style: italic; }
  .bubble-text .cursor {
    display: inline-block; width: 2px; height: 14px;
    background: #1a2a4a; margin-left: 2px; vertical-align: middle;
    animation: blink 0.8s step-end infinite;
