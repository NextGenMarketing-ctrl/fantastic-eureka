    overflow-y: auto;
    z-index: 30;
    opacity: 0; pointer-events: none;
    transition: opacity 0.4s ease-out,
                top 0.65s cubic-bezier(0.77,0,0.175,1),
                left 0.65s cubic-bezier(0.77,0,0.175,1),
