<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Palmer — Portfolio Orb</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Rajdhani:wght@300;400;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --c-cyan:    #0066cc;
    --c-blue:    #1a4fff;
    --c-teal:    #007a66;
    --c-violet:  #5a1fcc;
    --c-amber:   #b87800;
    --c-red:     #cc2244;
    --c-dim:     rgba(0,60,120,0.06);
    --c-border:  rgba(0,60,120,0.15);
    --font-hud:  'Space Mono', monospace;
    --font-ui:   'Rajdhani', sans-serif;
  }

  body {
    margin: 0;
    overflow-x: hidden;
    overflow-y: auto;
    background: #eeede8;
    font-family: var(--font-ui);
    color: #1a1a2e;
  }

  canvas { display: block; z-index: 1; position: fixed; top: 0; left: 0; width: 100% !important; height: 100% !important; }
  #burst-canvas { z-index: 2; }
  #scanline { z-index: 3; }

  #neural-canvas {
    position: fixed;
    inset: 0;
    z-index: 4;
    pointer-events: none;
  }

  .hud-corner {
    position: fixed;
    width: 40px;
    height: 40px;
    pointer-events: none;
    opacity: 0.5;
  }
  .hud-corner::before, .hud-corner::after {
    content: '';
    position: absolute;
    background: var(--c-cyan);
  }
  .hud-corner::before { width: 2px; height: 20px; }
  .hud-corner::after  { width: 20px; height: 2px; }
  .hud-corner.tl { top: 16px; left: 16px; }
  .hud-corner.tl::before { top: 0; left: 0; }
  .hud-corner.tl::after  { top: 0; left: 0; }
  .hud-corner.tr { top: 16px; right: 16px; }
  .hud-corner.tr::before { top: 0; right: 0; }
  .hud-corner.tr::after  { top: 0; right: 0; }
  .hud-corner.bl { bottom: 16px; left: 16px; }
  .hud-corner.bl::before { bottom: 0; left: 0; }
  .hud-corner.bl::after  { bottom: 0; left: 0; }
  .hud-corner.br { bottom: 16px; right: 16px; }
  .hud-corner.br::before { bottom: 0; right: 0; }
  .hud-corner.br::after  { bottom: 0; right: 0; }

  #status-bar {
    position: fixed;
    top: 24px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-hud);
    font-size: 10px;
    letter-spacing: 0.18em;
    color: rgba(20,40,80,0.45);
    pointer-events: none;
    text-transform: uppercase;
    white-space: nowrap;
  }
  #status-bar span { color: #0055aa; opacity: 0.8; }

  #section-panel {
    position: fixed;
    right: 32px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 10px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  #section-panel.visible { opacity: 1; pointer-events: auto; }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
    padding: 8px 14px 8px 10px;
    border: 1px solid var(--c-border);
    border-radius: 4px;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(12px);
    transition: border-color 0.2s, background 0.2s, transform 0.2s;
    font-family: var(--font-ui);
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: rgba(255,255,255,0.75);
    text-transform: uppercase;
  }
  .nav-item:hover {
    border-color: var(--c-cyan);
    background: rgba(0,245,255,0.06);
    color: #fff;
    transform: translateX(-4px);
  }
  .nav-item.active {
    border-color: var(--c-cyan);
    color: var(--c-cyan);
    background: rgba(0,245,255,0.08);
  }
  .nav-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
    flex-shrink: 0;
    opacity: 0.6;
    transition: opacity 0.2s, transform 0.2s;
  }
  .nav-item:hover .nav-dot,
  .nav-item.active .nav-dot { opacity: 1; transform: scale(1.4); }

  #theme-bar {
    position: fixed;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 10px 18px;
    background: rgba(255,255,255,0.55);
    border: 1px solid rgba(0,40,100,0.12);
    border-radius: 40px;
    backdrop-filter: blur(16px);
    z-index: 10;
  }
  .theme-swatch {
    width: 26px; height: 26px;
    border-radius: 50%;
    cursor: pointer;
    border: 2px solid rgba(255,255,255,0.15);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .theme-swatch:hover  { transform: scale(1.2); }
  .theme-swatch.active { border-color: #fff; box-shadow: 0 0 14px rgba(255,255,255,0.5); transform: scale(1.2); }

  .ctrl-btn {
    width: 26px; height: 26px;
    border-radius: 50%;
    cursor: pointer;
    border: 1px solid rgba(255,255,255,0.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-family: var(--font-hud); color: #fff;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .ctrl-btn:hover { transform: scale(1.2); box-shadow: 0 0 12px var(--c-cyan); }

  #explode-btn  { background: linear-gradient(135deg, #00c9a7, #1a6fff); }
  #explode-btn.active { pointer-events: none; opacity: 0.6; }
  #fs-btn       { background: rgba(255,255,255,0.08); font-size: 9px; letter-spacing: 0.05em; }

  #tooltip {
    position: fixed;
    padding: 6px 12px;
    background: rgba(0,0,0,0.8);
    border: 1px solid var(--c-cyan);
    border-radius: 4px;
    font-family: var(--font-hud);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--c-cyan);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s;
    white-space: nowrap;
    z-index: 20;
  }
  #tooltip.show { opacity: 1; }

  #section-overlay {
    position: fixed;
    left: 32px;
    top: 50%;
    transform: translateY(-50%);
    max-width: 340px;
    padding: 28px 32px;
    background: rgba(0,0,0,0.75);
    border: 1px solid var(--c-border);
    border-radius: 8px;
    backdrop-filter: blur(20px);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  #section-overlay.visible { opacity: 1; pointer-events: auto; }

  .overlay-tag {
    font-family: var(--font-hud);
    font-size: 9px;
    letter-spacing: 0.22em;
    color: var(--c-cyan);
    text-transform: uppercase;
    margin-bottom: 10px;
    opacity: 0.7;
  }
  .overlay-title {
    font-family: var(--font-ui);
    font-size: 28px;
    font-weight: 600;
    letter-spacing: 0.04em;
    line-height: 1.1;
    margin-bottom: 12px;
    color: #fff;
  }
  .overlay-desc {
    font-size: 14px;
    font-weight: 300;
    line-height: 1.65;
    color: rgba(255,255,255,0.55);
    margin-bottom: 20px;
  }
  .overlay-close {
    font-family: var(--font-hud);
    font-size: 10px;
    letter-spacing: 0.14em;
    color: rgba(0,245,255,0.5);
    cursor: pointer;
    text-transform: uppercase;
    border: none;
    background: none;
    padding: 0;
    transition: color 0.2s;
  }
  .overlay-close:hover { color: var(--c-cyan); }

  @keyframes scan {
    0%   { top: -10%; opacity: 0; }
    10%  { opacity: 0.04; }
    90%  { opacity: 0.04; }
    100% { top: 110%; opacity: 0; }
  }
  #scanline {
    position: fixed; left: 0; width: 100%;
    height: 2px;
    background: rgba(0,60,120,0.15);
    pointer-events: none;
    animation: scan 8s linear infinite;
    z-index: 3;
  }

  #greeting {
    position: fixed;
    top: 52%;
    left: 50%;
    transform: translate(-50%, -50%);
    padding: 0 36px;
    text-align: center;
    pointer-events: auto;
    white-space: nowrap;
    z-index: 10;
    transition: opacity 0.4s ease, transform 0.4s ease;
    background: none;
    border: none;
    box-shadow: none;
  }
  #greeting-name {
    font-family: var(--font-ui);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.28em;
    color: rgba(20,30,60,0.45);
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  #greeting-line {
    font-family: var(--font-ui);
    font-size: 42px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: rgba(20,30,60,1);
    white-space: normal;
    max-width: min(600px, 90vw);
    margin: 0 auto;
  }
  #greeting-line span {
    font-weight: 300;
    color: rgba(20,30,60,0.65);
    font-size: 42px;
  }
  #greeting-sub {
    font-family: var(--font-ui);
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.01em;
    color: rgba(20,30,60,0.6);
    text-transform: none;
    margin-top: 10px;
  }
  /* ── Apple-style nav bar (replaces chips) ── */
  #suggestions {
    position: fixed;
    top: 42%;
    left: 50%;
    transform: translateX(-50%);
    padding-top: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: opacity 0.3s ease;
  }
  #suggestions.hidden { opacity: 0; pointer-events: none; }

  .apple-nav {
    display: flex;
    align-items: center;
    gap: 0;
    background: rgba(255,255,255,0.72);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 100px;
    padding: 0 4px;
    box-shadow: 0 2px 20px rgba(0,0,0,0.07), inset 0 1px 0 rgba(255,255,255,0.9);
  }

  .apple-nav-item {
    font-family: -apple-system, 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 13px;
    font-weight: 400;
    letter-spacing: -0.01em;
    color: rgba(0,0,0,0.65);
    padding: 10px 20px;
    cursor: pointer;
    white-space: nowrap;
    border-radius: 100px;
    transition: color 0.15s ease, background 0.15s ease;
    user-select: none;
  }
  .apple-nav-item:hover {
    color: rgba(0,0,0,0.92);
    background: rgba(0,0,0,0.05);
  }

  .apple-nav-divider {
    width: 1px;
    height: 16px;
    background: rgba(0,0,0,0.12);
    flex-shrink: 0;
    border-radius: 1px;
  }

  @property --orb-rotation {
    syntax: '<angle>';
    inherits: false;
    initial-value: 0deg;
  }
  @keyframes orb-rotate {
    to { --orb-rotation: 360deg; }
  }

  .gemini {
    --border-size: 1px;
    --orb-gradient: conic-gradient(
      from var(--orb-rotation) at 52% 49% in oklab,
      rgba(0,180,200,0.5)   0%,
      rgba(20,90,200,0.4)   25%,
      rgba(0,160,130,0.5)   50%,
      rgba(0,50,200,0.3)    75%,
      rgba(0,180,200,0.5)   100%
    );
    animation: orb-rotate 6s infinite linear;
    border-radius: 3rem;
    background: none;
    position: relative;
    padding: 0;
    border: none;
    width: 100%;
    overflow: hidden;
  }
  .gemini::after {
    content: '';
    position: absolute;
    display: block;
    width: 140%;
    height: 140%;
    background: var(--orb-gradient);
    top: 50%;
    left: 50%;
    translate: -50% -50%;
    z-index: -1;
    animation: orb-rotate 6s infinite linear;
    filter: blur(18px);
    opacity: 0.25;
    border-radius: 50%;
  }
  .gemini .inner {
    background: rgba(255,255,255,0.6);
    backdrop-filter: blur(28px) saturate(180%);
    -webkit-backdrop-filter: blur(28px) saturate(180%);
    border: 1px solid rgba(0,40,100,0.1);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.85),
      inset 0 -1px 0 rgba(0,0,0,0.04),
      0 6px 28px rgba(0,0,0,0.07);
    color: rgba(20,30,60,0.7);
    padding: 0.85rem 1.1rem;
    position: relative;
    z-index: 2;
    border-radius: inherit;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-hud);
  }
  .gemini .border {
    position: absolute;
    inset: calc(var(--border-size) * -1);
    mask: linear-gradient(white);
    border-radius: inherit;
    overflow: hidden;
  }
  .gemini .border::after {
    content: '';
    position: absolute;
    width: 100%;
    height: 100%;
    background: var(--orb-gradient);
    top: 50%;
    left: 50%;
    translate: -50% -50%;
    z-index: -1;
    filter: blur(3px);
    opacity: 0.5;
    animation: orb-rotate 6s infinite linear;
  }
  .gemini button {
    background: none;
    border: none;
    color: rgba(10,20,50,0.55);
    cursor: pointer;
    font-size: 18px;
    line-height: 1;
    padding: 2px 4px;
    transition: color 0.2s;
    display: flex;
    align-items: center;
  }
  .gemini button:hover { color: rgba(10,20,50,0.9); }
  .gemini input {
    background: none;
    border: none;
    color: rgba(10,20,50,0.9);
    font-family: var(--font-hud);
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    width: 100%;
  }
  .gemini input::placeholder {
    color: rgba(10,20,50,0.28);
    letter-spacing: 0.1em;
    font-size: 0.8rem;
  }
  .gemini input:focus { outline: none; color: #1a1a2e; }
  .gemini .send-btn {
    background: none; border: none;
    color: rgba(0,245,255,0.45);
    cursor: pointer; padding: 2px 4px; display: flex; align-items: center;
    transition: color 0.2s; flex-shrink: 0;
  }
  .gemini .send-btn:hover { color: var(--c-cyan); }
  .gemini .send-btn.active { color: var(--c-cyan); }

  /* ── Old nav-arrows hidden — replaced by cortex-nav ── */
  #nav-arrows { display: none !important; }

  /* ── Cortex navigation bar ── */
  #cortex-nav {
    position: fixed;
    top: 68px;
    left: 50%;
    transform: translateX(-50%);
    width: min(860px, calc(100vw - 32px));
    display: flex;
    align-items: center;
    gap: 6px;
    z-index: 25;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }
  #cortex-nav.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .cnav-btn {
    height: 32px;
    border-radius: 20px;
    border: 1px solid rgba(20,30,60,0.14);
    background: rgba(255,255,255,0.72);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
    cursor: pointer;
    transition: background 0.18s, border-color 0.18s, transform 0.14s, box-shadow 0.18s;
    color: rgba(20,30,60,0.6);
    user-select: none;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    font-family: var(--font-hud);
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    white-space: nowrap;
    padding: 0 14px;
  }
  .cnav-btn:hover {
    background: rgba(255,255,255,0.95);
    border-color: rgba(20,30,60,0.28);
    color: rgba(20,30,60,0.9);
    transform: translateY(-1px);
    box-shadow: 0 4px 18px rgba(0,0,0,0.10);
  }
  .cnav-btn.icon-only {
    width: 32px;
    padding: 0;
  }
  .cnav-btn.disabled {
    opacity: 0.28;
    pointer-events: none;
  }
  .cnav-btn svg { flex-shrink: 0; }

  /* divider pip between btn groups */
  .cnav-sep {
    width: 1px;
    height: 18px;
    background: rgba(20,30,60,0.12);
    margin: 0 2px;
  }
  #cnav-counter {
    font-family: var(--font-hud);
    font-size: 9px;
    letter-spacing: 0.1em;
    color: rgba(20,30,60,0.38);
    min-width: 32px;
    text-align: center;
    padding: 0 2px;
  }

  #boot-overlay {
    position: fixed; inset: 0;
    background: #eeede8;
    z-index: 100;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    pointer-events: none;
    transition: opacity 1.4s ease;
  }
  #boot-overlay.done { opacity: 0; pointer-events: none; }

  #boot-orb {
    position: relative; width: 80px; height: 80px; margin-bottom: 36px;
  }
  #boot-orb-core {
    position: absolute; inset: 0; border-radius: 50%;
    background: radial-gradient(circle at 38% 36%, #1a1a2e, #0a0a18, #050510);
    border: 1px solid rgba(20,30,60,0.15);
    animation: core-assemble 2.4s ease-out forwards;
    opacity: 0;
  }
  @keyframes core-assemble {
    0%   { opacity:0; transform: scale(0.1); filter: blur(10px); }
    40%  { opacity:0.7; transform: scale(1.12); filter: blur(2px); }
    70%  { opacity:1; transform: scale(0.96); filter: blur(0); }
    100% { opacity:1; transform: scale(1); filter: blur(0); }
  }
  .boot-ring {
    position: absolute; border-radius: 50%;
    border: 1px solid rgba(20,30,60,0.18);
    top: 50%; left: 50%; transform: translate(-50%,-50%);
    animation: ring-converge var(--dur) ease-out var(--delay) forwards;
    opacity: 0;
  }
  @keyframes ring-converge {
    0%   { opacity:0.7; transform: translate(-50%,-50%) scale(var(--start-scale)); }
    80%  { opacity:0.3; transform: translate(-50%,-50%) scale(1.04); }
    100% { opacity:0;   transform: translate(-50%,-50%) scale(1); }
  }
  #boot-text {
    font-family: var(--font-hud); font-size: 10px; letter-spacing: 0.22em;
    color: rgba(20,30,60,0.45); text-transform: uppercase; text-align: center;
    line-height: 2.4;
  }
  #boot-bar-wrap {
    width: 180px; height: 1px; background: rgba(20,30,60,0.1);
    border-radius: 2px; margin-top: 24px; overflow: hidden;
  }
  #boot-bar {
    height: 100%; width: 0%; background: rgba(20,30,60,0.35);
    transition: width 0.1s linear; border-radius: 2px;
  }

  #search-wrap {
    position: fixed;
    top: 46%;
    left: 50%;
    transform: translateX(-50%);
    z-index: 20;
    width: min(560px, 88vw);
    transition: top 0.65s cubic-bezier(0.77,0,0.175,1),
                left 0.65s cubic-bezier(0.77,0,0.175,1),
                width 0.65s cubic-bezier(0.77,0,0.175,1),
                transform 0.65s cubic-bezier(0.77,0,0.175,1),
                box-shadow 0.65s ease;
  }
  #search-wrap.docked {
    top: 16px;
    left: 50%;
    width: min(860px, calc(100vw - 32px));
    transform: translateX(-50%);
    box-shadow: 0 2px 24px rgba(0,0,0,0.08);
    z-index: 51;
  }

  #greeting-availability {
    display: flex;
    align-items: center;
    gap: 8px;
    justify-content: center;
    margin-top: 14px;
    font-family: var(--font-ui);
    font-size: 13px;
    font-weight: 400;
    color: rgba(20,30,60,0.55);
  }
  #avail-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 0 3px rgba(34,197,94,0.2);
    animation: pulse-green 2s ease infinite;
    flex-shrink: 0;
  }
  @keyframes pulse-green {
    0%, 100% { box-shadow: 0 0 0 3px rgba(34,197,94,0.2); }
    50%       { box-shadow: 0 0 0 6px rgba(34,197,94,0.08); }
  }
  #avail-email {
    color: rgba(20,30,60,0.75);
    font-weight: 500;
    text-decoration: none;
    border-bottom: 1px solid rgba(20,30,60,0.2);
    transition: color 0.15s, border-color 0.15s;
  }
  #avail-email:hover { color: rgba(20,30,60,1); border-color: rgba(20,30,60,0.6); }

  /* ── Landing project cards — below nav pill ── */
  #landing-cards {
    position: fixed;
    top: 73%;
    left: 50%;
    transform: translateX(-50%);
    width: min(900px, calc(100vw - 32px));
    z-index: 15;
    display: flex;
    flex-direction: column;
    gap: 0;
    pointer-events: auto;
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  #landing-cards.hidden {
    opacity: 0;
    pointer-events: none;
    transform: translateX(-50%) translateY(16px);
  }
  /* Search bar hidden on landing, shown only when docked */
  #search-wrap { display: none; }
  #search-wrap.docked { display: block; }
  #landing-cards-label {
    font-family: var(--font-hud);
    font-size: 8px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(20,30,60,0.3);
    text-align: center;
    margin-bottom: 10px;
  }
  #landing-cards-grid {
    display: grid;
