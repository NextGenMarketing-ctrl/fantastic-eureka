  function makeTerminalShell(action){
    const data = TERMINAL_CONTENT[action] || TERMINAL_CONTENT.projects;
    const overlay = document.getElementById('page-overlay');
    const content = document.getElementById('page-content');
    if(!overlay || !content) return null;
    overlay.classList.add('terminal-page-mode', 'open');
    document.body.style.overflow='hidden';
    overlay.scrollTop = 0;
    content.innerHTML = `
      <section class="terminal-page" data-terminal-action="${action}">
        <div class="terminal-titlebar">
          <div class="terminal-window-label">${data.label}</div>
          <div class="terminal-window-path">${data.path}</div>
        </div>
        <div class="terminal-output" id="terminal-output"></div>
        <div class="terminal-result-grid" id="terminal-result-grid"></div>
        <div class="terminal-action-row" id="terminal-action-row"></div>
      </section>
    `;
    return { data, output: content.querySelector('#terminal-output'), grid: content.querySelector('#terminal-result-grid'), actions: content.querySelector('#terminal-action-row') };
  }

  function typeLine(el, text, className, done){
    const line = document.createElement('span');
    line.className = 'term-line ' + (className || '');
    el.appendChild(line);
    let i = 0;
    const cursor = document.createElement('span');
    cursor.className = 'term-cursor-inline';
    line.appendChild(cursor);
    function tick(){
      line.textContent = text.slice(0, i);
      line.appendChild(cursor);
      i++;
      if(i <= text.length){
        terminalTimer = setTimeout(tick, className === 'dim' ? 7 : 13);
      } else {
        cursor.remove();
        done && done();
      }
    }
    tick();
  }

  function revealCards(grid, cards){
    grid.innerHTML = cards.map(card => `
      <article class="term-card">
        <div class="term-card-kicker">${card[0]}</div>
        <div class="term-card-title">${card[1]}</div>
        <div class="term-card-body">${card[2]}</div>
        ${card[3] ? `<div class="term-card-link">${card[3]}</div>` : ''}
      </article>
    `).join('');
    requestAnimationFrame(() => grid.classList.add('ready'));
  }

  function revealActions(row, actions){
    row.innerHTML = actions.map(([label, target]) => `<button class="term-action" data-target="${target}">${label}</button>`).join('');
