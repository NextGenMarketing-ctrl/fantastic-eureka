/* ══ CARD MORPH SYSTEM ══
 *
 * How it works:
 * 1. On card click — getBoundingClientRect() captures exact card position
 * 2. morph-card is positioned/sized identically to that card (instant, no transition)
 * 3. On next frame, CSS transitions fire: top/left/width/height animate to fullscreen
 * 4. After transition ends (440ms), content fades in, summary fades out
 * 5. On close: reverse — content fades, card shrinks back to origin rect, then hides
 */

const morphOverlay  = document.getElementById('morph-overlay');
const morphCard     = document.getElementById('morph-card');
const morphSummary  = document.getElementById('morph-card-summary');
const morphContent  = document.getElementById('morph-card-content');
const morphInner    = document.getElementById('morph-inner');
const morphEmoji    = document.getElementById('morph-summary-emoji');
const morphLabel    = document.getElementById('morph-summary-label');
const morphTitle    = document.getElementById('morph-summary-title');
const morphCloseBtn = document.getElementById('morph-close-btn');

let morphOriginRect = null;
let morphActive     = false;
let morphFromSelector = false; // track if opened from the casestudies selector

function morphOpen(cardEl, pageId) {
  if(morphActive) return;
  morphActive = true;
  // Were we inside the casestudies page-overlay when this was clicked?
  morphFromSelector = !!document.getElementById('page-overlay').classList.contains('open');
  // Hide landing cards during morph
  document.getElementById('landing-cards')?.classList.add('hidden');
  // Close the selector overlay cleanly (no animation needed — morph card covers it)
  if(morphFromSelector) {
    PAGE_OVERLAY.classList.remove('open');
    document.body.style.overflow = 'hidden'; // keep locked
  }

  // Load the case study content
  const tpl = document.getElementById('tpl-' + pageId);
  if(!tpl) { morphActive = false; return; }
  morphInner.innerHTML = '';
  morphInner.appendChild(tpl.content.cloneNode(true));

  // Inject headshot if needed
  const hs = morphInner.querySelector('#about-headshot');
  if(hs) hs.src = PALMER_HEADSHOT;

  // Populate the summary strip
  morphEmoji.textContent = cardEl.dataset.emoji || '';
  morphLabel.textContent = cardEl.dataset.label || '';
  morphTitle.textContent = cardEl.dataset.title || '';

  // Step 1: capture card rect
  morphOriginRect = cardEl.getBoundingClientRect();
  const r = morphOriginRect;

  // Step 2: position morph-card exactly over the real card — NO transition yet
  morphCard.style.transition = 'none';
  morphCard.style.display    = 'block';
  morphCard.style.top        = r.top  + 'px';
  morphCard.style.left       = r.left + 'px';
  morphCard.style.width      = r.width + 'px';
  morphCard.style.height     = r.height + 'px';
  morphCard.style.borderRadius = '14px';
  morphCard.style.boxShadow  = '0 4px 24px rgba(0,0,0,0.08)';

  // Summary visible, content hidden
  morphSummary.classList.remove('hidden');
  morphContent.classList.remove('visible');
  morphContent.scrollTop = 0;

  // Dim siblings
  cardEl.classList.add('morphed');
  cardEl.closest('.cs-grid')?.querySelectorAll('.cs-card:not(.morphed)')
    .forEach(c => c.classList.add('morphed'));

  // Show overlay
  morphOverlay.classList.add('active');

  // Prevent bg scroll
  document.body.style.overflow = 'hidden';

  // Step 3: on next frame, re-enable transitions and animate to fullscreen
  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      morphCard.style.transition = [
        'top    0.44s cubic-bezier(0.77,0,0.175,1)',
        'left   0.44s cubic-bezier(0.77,0,0.175,1)',
        'width  0.44s cubic-bezier(0.77,0,0.175,1)',
        'height 0.44s cubic-bezier(0.77,0,0.175,1)',
        'border-radius 0.44s cubic-bezier(0.77,0,0.175,1)',
        'box-shadow 0.44s cubic-bezier(0.77,0,0.175,1)',
      ].join(',');

      const padding = window.innerWidth < 600 ? 0 : 24;
      const maxW    = window.innerWidth < 600 ? window.innerWidth : Math.min(860, window.innerWidth - 48);
      const left    = (window.innerWidth - maxW) / 2;
      const top     = window.innerWidth < 600 ? 0 : padding;

      morphCard.style.top          = top + 'px';
      morphCard.style.left         = left + 'px';
      morphCard.style.width        = maxW + 'px';
      morphCard.style.height       = (window.innerHeight - top - (window.innerWidth < 600 ? 0 : padding)) + 'px';
      morphCard.style.borderRadius = window.innerWidth < 600 ? '20px 20px 0 0' : '16px';
      morphCard.style.boxShadow    = '0 24px 80px rgba(0,0,0,0.18)';
    });
  });

  // Step 4: after transition, fade in content, fade out summary
  setTimeout(() => {
    morphSummary.classList.add('hidden');
    morphContent.classList.add('visible');

    // Stagger in sections inside content
    morphInner.querySelectorAll('.page-section, .page-hero, .page-tools-row').forEach((el, i) => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(16px)';
      el.style.transition = `opacity 0.35s ease ${i * 60}ms, transform 0.35s ease ${i * 60}ms`;
      requestAnimationFrame(() => {
        el.style.opacity = '1';
        el.style.transform = 'translateY(0)';
      });
    });

    // Fire Cortex if docked
    const triggers = {
      awardco:    'Tell me about the Awardco UX project',
      craigslist: 'Tell me about the Middle Earth Shire Quest Pass project',
      hershey:    'Tell me about the HersheyHome project',
    };
    if(triggers[pageId] && window.CORTEX_DOCKED && typeof askCortex === 'function') {
      askCortex(triggers[pageId]);
    }
  }, 460);
}

function morphClose() {
  if(!morphActive || !morphOriginRect) return;

  // Clear Cortex response panel so it doesn't accumulate
  if(responsePanel) {
    setTimeout(() => {
      responsePanel.innerHTML = '';
      conversationHistory = [];
    }, 300);
  }

  // Fade content out first
  morphContent.classList.remove('visible');
  morphSummary.classList.remove('hidden');

  // Un-dim siblings after a beat
  setTimeout(() => {
    document.querySelectorAll('.cs-card.morphed').forEach(c => c.classList.remove('morphed'));
  }, 200);

  // Re-position morph card back to origin
  const r = morphOriginRect;
  morphCard.style.top          = r.top  + 'px';
  morphCard.style.left         = r.left + 'px';
  morphCard.style.width        = r.width + 'px';
  morphCard.style.height       = r.height + 'px';
  morphCard.style.borderRadius = '14px';
  morphCard.style.boxShadow    = '0 4px 24px rgba(0,0,0,0.08)';

  // Hide overlay
  morphOverlay.classList.remove('active');
  document.body.style.overflow = '';

  // After transition, fully hide the morph card
  setTimeout(() => {
    morphCard.style.display = 'none';
    morphCard.style.transition = 'none';
    morphOriginRect = null;
    morphActive = false;
    // Return to the case study selector if that's where the user came from
    if(morphFromSelector) {
      openPage('casestudies');
      morphFromSelector = false;
    } else {
      // Came from landing — restore landing cards
      document.getElementById('landing-cards')?.classList.remove('hidden');
    }
  }, 460);
}

// Wire close button and overlay click
if(morphCloseBtn) morphCloseBtn.addEventListener('click', morphClose);
morphOverlay.addEventListener('click', morphClose);
document.addEventListener('keydown', e => { if(e.key === 'Escape' && morphActive) morphClose(); });

// Wire cs-cards via event delegation (works even inside modals/templates)
document.addEventListener('click', e => {
  const card = e.target.closest('[data-morph]');
  if(card) {
    e.preventDefault();
    morphOpen(card, card.dataset.morph);
  }
});



