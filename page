  .skill-row { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 10px; }
  .skill-pill {
    font-family: var(--font-hud); font-size: 9px; letter-spacing: 0.08em;
    padding: 3px 10px; border-radius: 20px;
