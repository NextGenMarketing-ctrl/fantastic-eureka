    box-shadow: 0 6px 24px rgba(0,0,0,0.08);
  }
  .card-label {
    font-family: var(--font-hud); font-size: 9px; letter-spacing: 0.18em;
    color: rgba(0,60,120,0.5); text-transform: uppercase; margin-bottom: 7px;
  }
  .card-title {
    font-family: var(--font-ui); font-size: 16px; font-weight: 600;
    color: rgba(20,30,60,0.9); margin-bottom: 5px; letter-spacing: 0.02em;
  }
  .card-body {
    font-family: var(--font-ui); font-size: 13px; font-weight: 300;
    color: rgba(20,30,60,0.6); line-height: 1.6;
  }
  .card-tag {
    display: inline-block; margin-top: 7px; padding: 2px 8px;
    border-radius: 20px; font-family: var(--font-hud); font-size: 8px;
    letter-spacing: 0.1em; text-transform: uppercase;
