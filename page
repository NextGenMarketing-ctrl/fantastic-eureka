    spawnBurst(innerWidth/2,innerHeight*.62,'#00f5ff');
    runCinematicTransition().then(()=>askCortex(val));
  } else {
    setOrbState('listening');
    setTimeout(()=>askCortex(val),200);
  }
}

function showResponsePanel(){ responsePanel.classList.add('visible'); }

function addUserBubble(text){
  const b=document.createElement('div'); b.className='user-bubble';
  b.dataset.exchange=exchangeCount+1;
  b.innerHTML=`<div class="user-bubble-text">${text}</div>`;
  responsePanel.appendChild(b); responsePanel.scrollTop=responsePanel.scrollHeight;
}

function addThinkingBubble(){
  const b=document.createElement('div'); b.className='response-bubble'; b.id='thinking-bubble';
  b.dataset.exchange=exchangeCount+1;
  b.innerHTML=`<div class="bubble-tag">Cortex</div><div class="thinking-dots"><span></span><span></span><span></span></div>`;
  responsePanel.appendChild(b); responsePanel.scrollTop=responsePanel.scrollHeight;
  return b;
}

let exchangeCount=0;

function replaceThinkingWithStream(){
  const old=document.getElementById('thinking-bubble');
  if(old) old.remove();
  exchangeCount++;
  const b=document.createElement('div'); b.className='response-bubble';
  b.id=`stream-bubble-${exchangeCount}`; b.dataset.exchange=exchangeCount;
  b.innerHTML=`<div class="bubble-tag">Cortex</div><div class="bubble-text" id="stream-text-${exchangeCount}"><span class="cursor"></span></div>`;
  responsePanel.appendChild(b); responsePanel.scrollTop=responsePanel.scrollHeight;
  return document.getElementById(`stream-text-${exchangeCount}`);
}

/* ── Exchange state ── */
let currentNavExchange = 0;

function scrollToExchange(n){
  const bubbles = responsePanel.querySelectorAll(`[data-exchange="${n}"]`);
  if(bubbles.length > 0) bubbles[0].scrollIntoView({behavior:'smooth', block:'start'});
}

/* ── Cortex nav bar ── */
const cortexNav = document.getElementById('cortex-nav');

function updateNavArrows(){
  const total = exchangeCount;
  const viewing = currentNavExchange === 0 ? total : currentNavExchange;

  // Show/hide nav bar (only when docked and at least 1 exchange)
  if(total >= 1 && hasTransitioned){
    cortexNav.classList.add('visible');
  } else {
    cortexNav.classList.remove('visible');
  }

  // Counter
  const counter = document.getElementById('cnav-counter');
  if(total <= 0){ counter.textContent = '—'; }
  else { counter.textContent = `${viewing} / ${total}`; }

  // Prev / next state
  document.getElementById('cnav-prev').classList.toggle('disabled', total <= 1 || viewing <= 1);
  document.getElementById('cnav-next').classList.toggle('disabled', total <= 1 || viewing >= total);
}

document.getElementById('cnav-prev').addEventListener('click', () => {
  const viewing = currentNavExchange === 0 ? exchangeCount : currentNavExchange;
  if(viewing > 1){
    currentNavExchange = viewing - 1;
    scrollToExchange(currentNavExchange);
    updateNavArrows();
  }
});

document.getElementById('cnav-next').addEventListener('click', () => {
  const viewing = currentNavExchange === 0 ? exchangeCount : currentNavExchange;
  if(viewing < exchangeCount){
    currentNavExchange = viewing + 1;
    if(currentNavExchange === exchangeCount) currentNavExchange = 0;
    scrollToExchange(currentNavExchange === 0 ? exchangeCount : currentNavExchange);
    updateNavArrows();
  }
});

