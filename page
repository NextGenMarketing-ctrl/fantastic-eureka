  /* ══ CARD MORPH SYSTEM ══ */

  /* The morph overlay — full screen backdrop */
  #morph-overlay {
    position: fixed;
    inset: 0;
    z-index: 399;
    pointer-events: none;
    opacity: 0;
    background: rgba(20,20,30,0.45);
    backdrop-filter: blur(0px);
    -webkit-backdrop-filter: blur(0px);
    transition: opacity 0.38s ease, backdrop-filter 0.38s ease;
  }
  #morph-overlay.active {
    opacity: 1;
    pointer-events: auto;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  /* The flying card clone that animates */
  #morph-card {
    position: fixed;
    z-index: 400;
    background: rgba(255,255,255,0.92);
    border: 1px solid rgba(20,30,60,0.08);
    border-radius: 14px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    overflow: hidden;
    transition:
      top    0.44s cubic-bezier(0.77,0,0.175,1),
      left   0.44s cubic-bezier(0.77,0,0.175,1),
      width  0.44s cubic-bezier(0.77,0,0.175,1),
      height 0.44s cubic-bezier(0.77,0,0.175,1),
      border-radius 0.44s cubic-bezier(0.77,0,0.175,1),
      box-shadow 0.44s cubic-bezier(0.77,0,0.175,1);
    will-change: top, left, width, height;
  }

  /* Card summary shown during morph (emoji + title) */
  #morph-card-summary {
    padding: 28px 28px 24px;
    transition: opacity 0.2s ease;
  }
  #morph-card-summary.hidden { opacity: 0; }

  /* Full case study content, fades in after morph */
  #morph-card-content {
    position: absolute;
    inset: 0;
    overflow-y: auto;
    padding: 0 0 40px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
    -webkit-overflow-scrolling: touch;
    z-index: 2;
  }
  #morph-card-content.visible {
    opacity: 1;
    pointer-events: auto;
  }

  /* Close button inside morph card */
  #morph-close {
    position: sticky;
    top: 0;
    display: flex;
    justify-content: flex-end;
    padding: 16px 20px 0;
    z-index: 10;
    background: linear-gradient(to bottom, rgba(255,255,255,0.95) 60%, transparent);
    pointer-events: auto;
  }
  #morph-close-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255,255,255,0.85);
    border: 1px solid rgba(20,30,60,0.12);
    border-radius: 6px;
    padding: 7px 14px;
    font-family: var(--font-hud);
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(20,30,60,0.65);
    cursor: pointer;
    pointer-events: auto;
    transition: background 0.15s, color 0.15s;
    min-height: 44px;
    -webkit-appearance: none;
    appearance: none;
  }
  #morph-close-btn:hover { background: rgba(255,255,255,1); color: rgba(20,30,60,0.9); }

  /* cs-cards in expanded state hide hover effects */
  .cs-card.morphed {
    opacity: 0.3;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

