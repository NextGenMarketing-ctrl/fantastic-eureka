  }
  .avatar-name {
    font-family: var(--font-ui); font-size: 16px; font-weight: 600;
    color: #1a1a2e; letter-spacing: 0.04em;
  }
  .avatar-role {
    font-family: var(--font-hud); font-size: 9px; letter-spacing: 0.14em;
    color: rgba(0,60,120,0.45); text-transform: uppercase; margin-top: 3px;
  }
  .timeline-title {
    font-family: var(--font-ui); font-size: 13px; font-weight: 600;
    color: rgba(20,30,60,0.85);
  }
  .timeline-sub {
    font-family: var(--font-hud); font-size: 9px; letter-spacing: 0.1em;
    color: rgba(0,60,120,0.4); margin-top: 2px;
  }
  .timeline-desc {
    font-family: var(--font-ui); font-size: 12px; font-weight: 300;
    color: rgba(20,30,60,0.5); margin-top: 3px; line-height: 1.5;
  }

  .response-bubble {
    background: rgba(255,255,255,0.65);
    backdrop-filter: blur(28px);
    -webkit-backdrop-filter: blur(28px);
    border: 1px solid rgba(0,40,100,0.1);
    border-radius: 12px;
    padding: 16px 20px;
    margin-bottom: 10px;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.9), 0 4px 20px rgba(0,0,0,0.06);
  }
  .bubble-tag {
    font-family: var(--font-hud); font-size: 8px; letter-spacing: 0.2em;
    color: rgba(0,60,120,0.5); text-transform: uppercase; margin-bottom: 8px;
  }
